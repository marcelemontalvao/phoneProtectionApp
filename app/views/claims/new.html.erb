<h1>Novo Sinistro</h1>

<%= form_with model: @claim do |f| %>
    <div>
        <%= f.label :claim_type %>
        <%= f.text_field :claim_type %>
    </div>

    <div>
        <%= f.label :description %>
        <%= f.text_area :description %>
    </div>

    <div>
        <%= f.label :status %>
        <%= f.text_field :status %>
    </div>

    <div>
        <%= f.label :phone_id %>
        <%= f.number_field :phone_id %>
    </div>

    <div>
        <%= f.submit "Salvar" %>
    </div>
<% end %>