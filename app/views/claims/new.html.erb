<h1>Novo Sinistro</h1>

<% if @claim && @claim.errors.any? %>
  <ul>
    <% @claim.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>

<%= form_with model: @claim do |f| %>
    <div>
        <%= f.label :claim_type %>
        <%= f.text_field :claim_type %>
    </div>

    <div>
        <%= f.label :description %>
        <%= f.text_area :description %>
    </div>

    <div>
        <%= f.label :status %>
        <%= f.text_field :status %>
    </div>

    <div>
        <%= f.label :phone_id %>
        <%= f.number_field :phone_id %>
    </div>

    <div>
        <%= f.submit "Salvar" %>
    </div>
<% end %>